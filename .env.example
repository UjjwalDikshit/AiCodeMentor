# CodeMentor AI — Environment Variables (Example)
# Copy this file to `.env` at the project root before running Docker Compose.
# For a checklist of values you must paste yourself, see REQUIRED_SECRETS/

# ── Application ──────────────────────────────────────────
NODE_ENV=development
APP_NAME=CodeMentor AI

# ── Frontend ─────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:5000/api/v1
VITE_SOCKET_URL=http://localhost:5000
VITE_AI_SERVICE_URL=http://localhost:8000

# ── Backend (Express) ────────────────────────────────────
BACKEND_PORT=5000
BACKEND_HOST=0.0.0.0
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:5173

# JWT (replace with long random secrets before production)
JWT_SECRET=change_me_jwt_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_jwt_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# MongoDB
MONGODB_URI=mongodb://mongo:27017/codementor_ai
# Local (outside Docker): mongodb://localhost:27017/codementor_ai

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# AI Service (internal)
AI_SERVICE_URL=http://ai-service:8000
AI_SERVICE_TIMEOUT_MS=60000

# ── AI Service (FastAPI infrastructure) ──────────────────
AI_SERVICE_PORT=8000
AI_SERVICE_HOST=0.0.0.0
AI_LOG_LEVEL=info

# Provider selection — switch with one variable: dummy | groq | ollama
AI_PROVIDER=dummy
CHAT_MODEL=llama-3.1-8b-instant
TEMPERATURE=0.2
MAX_TOKENS=2048
TOP_P=1.0
TOP_K=40

# Groq
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Embeddings — dummy | huggingface | nomic
EMBEDDING_PROVIDER=dummy
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
HF_TOKEN=

# ChromaDB
CHROMA_DIRECTORY=./data/chroma
CHROMA_COLLECTION=codementor_docs
# Legacy aliases (optional)
CHROMA_PERSIST_DIR=./data/chroma

# Legacy LLM vars (unused by provider factory — kept for compatibility)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=
LLM_MODEL=

# ── MongoDB container ────────────────────────────────────
MONGO_INITDB_DATABASE=codementor_ai
MONGO_PORT=27017

# ── Optional: GitHub OAuth (placeholder) ─────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:5000/api/v1/github/callback
