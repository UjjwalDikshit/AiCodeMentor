# Frontend env — Vite only exposes VITE_* variables to the browser.
# Prefer copying the root `.env.example` → root `.env` for Docker Compose.
# For local `npm run dev`, you can also copy this file to `frontend/.env`.

VITE_API_BASE_URL=http://localhost:5000/api/v1
VITE_SOCKET_URL=http://localhost:5000
VITE_AI_SERVICE_URL=http://localhost:8000
# Set to "true" only after real auth is implemented
VITE_ENFORCE_AUTH=false
