# Backend local overrides (optional). Root `.env` is preferred.
# Copy this file to `.env` (same folder) — the app does NOT load `.env.example`.

NODE_ENV=development
BACKEND_PORT=5000
BACKEND_HOST=0.0.0.0
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:5173
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/codementor_ai
JWT_SECRET=change_me_jwt_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_jwt_refresh_secret_min_32_chars
AI_SERVICE_URL=http://localhost:8000
