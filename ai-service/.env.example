CHAT_MODEL=llama-3.1-8b-instant
TEMPERATURE=0.2
MAX_TOKENS=2048
TOP_P=1.0
TOP_K=40

GROQ_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

EMBEDDING_PROVIDER=dummy
